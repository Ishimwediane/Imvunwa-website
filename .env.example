# ── Supabase ──────────────────────────────────────────────────
# Copy this file to ".env.local" and fill in the values from your
# Supabase project:  Project Settings → API
#
# These two are safe to expose in the browser (they are public keys;
# your data is protected by Row Level Security in the database).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Name of the Storage bucket that holds uploaded images (create it in
# Supabase → Storage). Defaults to "images" if not set.
NEXT_PUBLIC_SUPABASE_BUCKET=images
